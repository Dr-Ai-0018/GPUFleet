{
  "name": "gpufleet-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:types": "node ./scripts/generate-openapi-types.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts --fix",
    "lint:css": "stylelint \"src/**/*.{css,module.css}\"",
    "lint:css:full": "stylelint \"src/**/*.{css,module.css}\" --config .stylelintrc.full.cjs",
    "lint:colors": "node ./scripts/lint-colors.mjs",
    "lint:colors:full": "node ./scripts/lint-colors.mjs --strict",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,ts,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,ts,html}\"",
    "prepare": "cd .. && husky frontend/.husky",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "cmdk": "^1.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.1",
    "vitest": "^2.1.8"
  }
}
