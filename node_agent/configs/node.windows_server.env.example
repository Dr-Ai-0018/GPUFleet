GPUFLEET_AGENT_CONTROL_PLANE_URL=http://127.0.0.1:8000
GPUFLEET_AGENT_NODE_ID=node-win-5080
GPUFLEET_AGENT_NODE_SECRET=replace-after-registration
GPUFLEET_AGENT_HEARTBEAT_INTERVAL_SEC=5
GPUFLEET_AGENT_DEPLOYMENT_MODE=windows_server

GPUFLEET_AGENT_AGENT_ROOT=E:/GPUFleetNode
GPUFLEET_AGENT_REPOS_DIR=E:/GPUFleetNode/repos
GPUFLEET_AGENT_RUNS_DIR=E:/GPUFleetNode/runs
GPUFLEET_AGENT_ARTIFACTS_DIR=E:/GPUFleetNode/artifacts
GPUFLEET_AGENT_LOGS_DIR=E:/GPUFleetNode/logs
GPUFLEET_AGENT_STATE_DIR=E:/GPUFleetNode/state
GPUFLEET_AGENT_MODAL_PROFILES_DIR=E:/GPUFleetNode/modal_profiles

# Optional execution-manager hints. Leave blank to auto-discover from PATH.
GPUFLEET_AGENT_PYTHON_EXECUTABLE=
GPUFLEET_AGENT_VENV_PATH=
GPUFLEET_AGENT_UV_EXECUTABLE=
GPUFLEET_AGENT_CONDA_EXECUTABLE=
