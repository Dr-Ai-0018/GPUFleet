GPUFLEET_AGENT_CONTROL_PLANE_URL=http://127.0.0.1:8000
GPUFLEET_AGENT_NODE_ID=node-modal-runner
GPUFLEET_AGENT_NODE_SECRET=replace-after-registration
GPUFLEET_AGENT_NODE_SECRET_ENCRYPTED_PATH=./runtime/state/node_secret.enc
GPUFLEET_AGENT_NODE_SECRET_PASSPHRASE=replace-with-local-passphrase
GPUFLEET_AGENT_HEARTBEAT_INTERVAL_SEC=5
GPUFLEET_AGENT_DEPLOYMENT_MODE=cloud_gpu_runner

GPUFLEET_AGENT_AGENT_ROOT=/opt/gpufleet-modal-runner
GPUFLEET_AGENT_REPOS_DIR=/opt/gpufleet-modal-runner/repos
GPUFLEET_AGENT_RUNS_DIR=/opt/gpufleet-modal-runner/runs
GPUFLEET_AGENT_ARTIFACTS_DIR=/opt/gpufleet-modal-runner/artifacts
GPUFLEET_AGENT_LOGS_DIR=/opt/gpufleet-modal-runner/logs
GPUFLEET_AGENT_STATE_DIR=/opt/gpufleet-modal-runner/state
GPUFLEET_AGENT_MODAL_PROFILES_DIR=/opt/gpufleet-modal-runner/modal_profiles

# Optional execution-manager hints. Leave blank to auto-discover from PATH.
GPUFLEET_AGENT_PYTHON_EXECUTABLE=
GPUFLEET_AGENT_VENV_PATH=
GPUFLEET_AGENT_UV_EXECUTABLE=
GPUFLEET_AGENT_CONDA_EXECUTABLE=
GPUFLEET_AGENT_MICROMAMBA_EXECUTABLE=

# Keep real token pairs in a local-only JSON file copied from:
# node_agent/configs/modal_credentials.example.json
GPUFLEET_AGENT_MODAL_CREDENTIALS_PATH=/opt/gpufleet-modal-runner/secrets/modal_credentials.json
GPUFLEET_AGENT_MODAL_DEFAULT_CREDENTIAL_NAME=modal-main-01
GPUFLEET_AGENT_MODAL_DEFAULT_ENVIRONMENT=main
GPUFLEET_AGENT_MODAL_DEFAULT_WORKSPACE=
