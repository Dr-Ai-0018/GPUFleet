# ============================================================
# GPUFleet 节点 Agent 配置示例
# 使用方法：复制本文件为 .env，然后按需修改
# 也可以直接使用 configs/ 目录下对应平台的模板：
#   configs/node.windows_server.env.example
#   configs/node.linux_server.env.example
#   configs/node.modal_runner.env.example
# ============================================================


# ------------------------------------------------------------
# 控制平面连接（必填）
# ------------------------------------------------------------

# 控制平面的访问地址，节点通过此地址发送心跳和上报数据
# 如果控制平面在同一台机器上，使用 127.0.0.1
# 如果节点在其他机器上，填写控制平面的实际 IP 或域名
GPUFLEET_AGENT_CONTROL_PLANE_URL=http://127.0.0.1:8000

# 节点 ID，从控制台「节点接入」页面创建节点后获取
GPUFLEET_AGENT_NODE_ID=node-example

# 节点密钥，从控制台「节点接入」页面创建节点后获取
# 【必填】请勿将真实密钥提交到版本控制
GPUFLEET_AGENT_NODE_SECRET=replace-me

# 心跳发送间隔（秒）。建议与控制台中节点配置的值保持一致
# 有效范围：3 ~ 3600，默认 5 秒
GPUFLEET_AGENT_HEARTBEAT_INTERVAL_SEC=5

# 节点部署模式。可选值：
#   auto            - 自动检测（推荐）：有 Modal 凭证则选 cloud_gpu_runner，
#                     Windows 系统选 windows_server，否则选 linux_server
#   windows_server  - Windows 物理机 / 工作站
#   linux_server    - Linux 物理机 / 服务器
#   cloud_gpu_runner - Modal 云端 GPU 运行器
GPUFLEET_AGENT_DEPLOYMENT_MODE=auto


# ------------------------------------------------------------
# 本地运行时目录
# ------------------------------------------------------------
# 以下路径可以使用相对路径（相对于 node_agent/ 目录）或绝对路径
# 目录不存在时会自动创建

# Agent 运行时根目录
GPUFLEET_AGENT_AGENT_ROOT=./runtime

# Git 仓库克隆目录
GPUFLEET_AGENT_REPOS_DIR=./runtime/repos

# 任务运行临时目录（每个任务会在此创建子目录）
GPUFLEET_AGENT_RUNS_DIR=./runtime/runs

# 任务 Artifact 本地缓存目录
GPUFLEET_AGENT_ARTIFACTS_DIR=./runtime/artifacts

# 任务日志本地存储目录
GPUFLEET_AGENT_LOGS_DIR=./runtime/logs

# Agent 状态持久化目录（用于重启恢复）
GPUFLEET_AGENT_STATE_DIR=./runtime/state

# Modal 凭证 profile 缓存目录（仅 cloud_gpu_runner 模式使用）
GPUFLEET_AGENT_MODAL_PROFILES_DIR=./runtime/modal_profiles


# ------------------------------------------------------------
# Python 执行环境提示（可选）
# ------------------------------------------------------------
# 以下配置均为可选项。留空时 Agent 会自动从 PATH 中发现可用工具。
# 如果你的环境变量配置不标准，或者需要指定特定版本，才需要填写。

# 默认 Python 解释器路径
# 例：C:/Python312/python.exe 或 /usr/bin/python3
# 留空则使用 PATH 中的 python
GPUFLEET_AGENT_PYTHON_EXECUTABLE=

# 默认 venv 虚拟环境路径（用于 venv_path 执行后端）
# 例：E:/Project/MyProject/.venv 或 /home/user/project/.venv
# 留空则不预设默认 venv
GPUFLEET_AGENT_VENV_PATH=

# uv 可执行文件路径（用于 uv_project 执行后端）
# 例：C:/Users/user/.cargo/bin/uv.exe 或 /home/user/.cargo/bin/uv
# 留空则从 PATH 中自动查找 uv
GPUFLEET_AGENT_UV_EXECUTABLE=

# conda 可执行文件路径（用于 conda_name / conda_prefix 执行后端）
# 例：C:/ProgramData/miniconda3/Scripts/conda.exe 或 /opt/conda/bin/conda
# 留空则从 PATH 中自动查找 conda
GPUFLEET_AGENT_CONDA_EXECUTABLE=

# micromamba 可执行文件路径（用于 micromamba_prefix 执行后端）
# 例：C:/Users/user/micromamba/micromamba.exe 或 /usr/local/bin/micromamba
# 留空则从 PATH 中自动查找 micromamba
GPUFLEET_AGENT_MICROMAMBA_EXECUTABLE=


# ------------------------------------------------------------
# Modal 云端运行器配置（仅 cloud_gpu_runner 模式需要填写）
# ------------------------------------------------------------

# Modal 凭证池 JSON 文件路径
# 建议将此文件放在仓库目录之外，避免意外提交到版本控制
# 例：C:/secrets/modal_credentials.json 或 /home/user/.secrets/modal_creds.json
GPUFLEET_AGENT_MODAL_CREDENTIALS_PATH=

# 默认使用的凭证名称（对应 JSON 文件中的 key）
GPUFLEET_AGENT_MODAL_DEFAULT_CREDENTIAL_NAME=

# Modal 默认环境名称（对应 Modal 工作区中的 environment）
# 通常为 main
GPUFLEET_AGENT_MODAL_DEFAULT_ENVIRONMENT=main

# Modal 默认工作区名称（留空则使用凭证对应的默认工作区）
GPUFLEET_AGENT_MODAL_DEFAULT_WORKSPACE=
