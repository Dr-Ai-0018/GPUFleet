GPUFLEET_ENVIRONMENT=development
GPUFLEET_DEBUG=true
GPUFLEET_DATABASE_PATH=data/gpufleet.db
GPUFLEET_STORAGE_PATH=data/storage

GPUFLEET_JWT_SECRET=replace-this-before-public-deploy
GPUFLEET_ACCESS_TOKEN_EXPIRE_MINUTES=60
GPUFLEET_REFRESH_TOKEN_EXPIRE_MINUTES=10080

GPUFLEET_DEFAULT_ADMIN_USERNAME=admin
GPUFLEET_DEFAULT_ADMIN_PASSWORD=change-me-now

GPUFLEET_NODE_ALLOWED_CLOCK_SKEW_SEC=300
GPUFLEET_NONCE_TTL_SEC=600
GPUFLEET_MAX_STATUS_HISTORY_PER_NODE=200
