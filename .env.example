# ============================================================
# GPUFleet 控制平面配置示例
# 使用方法：复制本文件为 .env，然后按需修改
# ============================================================


# ------------------------------------------------------------
# 运行环境
# ------------------------------------------------------------

# 运行模式。可选值：development / production
# development 模式下会输出更详细的错误信息，不建议在公网部署时使用
GPUFLEET_ENVIRONMENT=development

# 是否开启调试模式。true 时 FastAPI 会返回完整的异常堆栈
# 生产环境请设为 false
GPUFLEET_DEBUG=true


# ------------------------------------------------------------
# 数据存储路径
# ------------------------------------------------------------

# SQLite 数据库文件路径（相对于项目根目录，或绝对路径）
# 目录不存在时会自动创建
GPUFLEET_DATABASE_PATH=data/gpufleet.db

# 任务日志、Artifact 等文件的存储根目录
# 目录不存在时会自动创建
GPUFLEET_STORAGE_PATH=data/storage


# ------------------------------------------------------------
# JWT 认证（必填）
# ------------------------------------------------------------

# JWT 签名密钥，用于签发和验证 access token / refresh token
# 【必填】部署前必须替换为随机字符串，建议 32 字节以上
# 生成示例：python -c "import secrets; print(secrets.token_hex(32))"
GPUFLEET_JWT_SECRET=replace-this-before-public-deploy

# 节点 signing key 的加密主密钥。留空时回退复用 JWT secret。
# 建议在生产环境单独配置，降低 DB 泄露后的密钥恢复风险。
GPUFLEET_NODE_KEY_ENCRYPTION_SECRET=

# Access Token 有效期（分钟）。默认 60 分钟
GPUFLEET_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh Token 有效期（分钟）。默认 10080 分钟（7 天）
GPUFLEET_REFRESH_TOKEN_EXPIRE_MINUTES=10080


# ------------------------------------------------------------
# 默认管理员账号（必填）
# ------------------------------------------------------------

# 首次启动时自动创建的管理员用户名
# 如果数据库中已有管理员账号，此配置不会覆盖已有数据
GPUFLEET_DEFAULT_ADMIN_USERNAME=admin

# 默认管理员密码
# 【必填】部署前必须修改为强密码
GPUFLEET_DEFAULT_ADMIN_PASSWORD=change-me-now


# ------------------------------------------------------------
# 节点安全策略
# ------------------------------------------------------------

# 允许节点心跳时间戳与服务器时间的最大偏差（秒）
# 用于防止重放攻击，默认 300 秒（5 分钟）
GPUFLEET_NODE_ALLOWED_CLOCK_SKEW_SEC=300

# 心跳 nonce 的有效期（秒）。超过此时间的 nonce 会被拒绝
# 默认 600 秒，应大于 CLOCK_SKEW 的两倍
GPUFLEET_NONCE_TTL_SEC=600

# 每个节点最多保留的历史状态快照条数
# 超出后自动删除最旧的记录，默认 200 条
GPUFLEET_MAX_STATUS_HISTORY_PER_NODE=200

# 单个 Artifact 文件的最大允许大小（字节）
# 默认 524288000（500 MB）
GPUFLEET_MAX_ARTIFACT_BYTES=524288000


# ------------------------------------------------------------
# AI 审核 (§1.5 Stage 1)
# ------------------------------------------------------------

# OpenAI 兼容 API 的 base URL。支持 OpenAI / Azure / vLLM / Ollama / LiteLLM 等
GPUFLEET_REVIEW_LLM_BASE_URL=https://api.openai.com/v1

# API Key。留空则 Stage 1 AI 审核跳过，L2 任务直接进入 Stage 3 人工审核
GPUFLEET_REVIEW_LLM_API_KEY=

# 审核用模型名称
GPUFLEET_REVIEW_LLM_MODEL=gpt-5.4

# 审核请求超时（秒），超时视为 uncertain，升级到人工审核
GPUFLEET_REVIEW_LLM_TIMEOUT_SEC=30

# 模型最大输出 token 数
GPUFLEET_REVIEW_LLM_MAX_TOKENS=1024

# 温度参数，审核场景建议低温
GPUFLEET_REVIEW_LLM_TEMPERATURE=0.1
